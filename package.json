{
  "name": "trustgraph",
  "version": "1.0.0",
  "description": "TrustGraph Technology Adoption Intelligence Platform",
  "main": "backend/main.py",
  "scripts": {
    "setup:backend": "pip install -r backend/requirements.txt",
    "setup:frontend": "npm install --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "start:backend": "python -m uvicorn backend.main:app --host 127.0.0.1 --port 8000 --reload",
    "start:frontend": "npm run dev --prefix frontend",
    "start": "python backend/main.py"
  }
}
